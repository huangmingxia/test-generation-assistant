<?xml version="1.0" encoding="UTF-8"?>
<workItems xmlns="http://polarion.com/xml-export">
    <workItem>
        <fields>
            <id>OCP-83946</id>
            <title>Ability to Override httpCustomErrorCodePages in ClusterDeployment</title>
            <description>
                <html>
                    <p xmlns="http://www.w3.org/1999/xhtml">
                        user story: 
                        <a class="descriptionLink" target="_top" href="https://issues.redhat.com/browse/HIVE-2040">https://issues.redhat.com/browse/HIVE-2040</a>
                    </p>
                </html>
            </description>
            <priority id="50.0" name="Medium"/>
            <status id="draft" name="Draft"/>
            <type id="testcase" name="Test Case"/>
        </fields>
        <customFields>
            <!-- Core test case fields -->
            <field id="casecomponent">
                <enum id="hive" name="Hive"/>
            </field>
            <field id="caseimportance">
                <enum id="critical" name="Critical"/>
            </field>
            <field id="caselevel">
                <enum id="component" name="Component"/>
            </field>
            <field id="caseautomation">
                <enum id="notautomated" name="Not Automated"/>
            </field>
            <field id="caseposneg">
                <enum id="positive" name="Positive"/>
            </field>
            <field id="testtype">
                <enum id="functional" name="Functional"/>
            </field>
            <field id="subteam">
                <enum id="cluster_operator" name="Cluster Operator"/>
            </field>
            <field id="products">
                <multi-enum>
                    <option id="ocp" name="OCP"/>
                </multi-enum>
            </field>
            <field id="version">
                <multi-enum>
                    <option id="4_20" name="4.20"/>
                </multi-enum>
            </field>
            <field id="trello">
                <string>HIVE-2040</string>
            </field>
            
            <!-- Test Steps - Complete structure for AI generation -->
            <field id="testSteps">
                <testSteps>
                    <keys>
                        <option id="step" name="Step"/>
                        <option id="expectedResult" name="Expected Result"/>
                    </keys>
                    <steps>
                        <!-- Step A: Create cluster with empty httpErrorCodePages -->
                        <testStep>
                            <values>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            A. Create a cluster with httpErrorCodePages.name set as empty.
                                            <br/>
                                            <br/>
                                            ingress:
                                            <br/>
                                            - domain: apps.{CLUSTER_NAME}.qe.devcluster.openshift.com
                                            <br/>
                                            httpErrorCodePages:
                                            <br/>
                                            name: ""
                                            <br/>
                                            name: default
                                        </p>
                                    </html>
                                </item>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            Cluster installation completes successfully and reaches "Provisioned" status with "Running" power state.
                                        </p>
                                    </html>
                                </item>
                            </values>
                        </testStep>
                        
                        <!-- Step 1: Verify empty httpErrorCodePages in SyncSet -->
                        <testStep>
                            <values>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            1. Verify that the httpErrorCodePages.name field in the SyncSet is an empty string "".
                                        </p>
                                    </html>
                                </item>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            SyncSet is created with httpErrorCodePages.name field set to empty string "".
                                        </p>
                                    </html>
                                </item>
                            </values>
                        </testStep>
                        
                        <!-- Step: Check IngressController in spoke cluster -->
                        <testStep>
                            <values>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            Log in to the spoke cluster and check the IngressController configuration.
                                        </p>
                                    </html>
                                </item>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            IngressController in spoke cluster has httpErrorCodePages.name field set to empty string "".
                                        </p>
                                    </html>
                                </item>
                            </values>
                        </testStep>
                        
                        <!-- Step B: Create cluster with custom httpErrorCodePages -->
                        <testStep>
                            <values>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            B. Create a ClusterDeployment with httpErrorCodePages.name set to a value, for example "custom-error-pages".
                                            <br/>
                                            <br/>
                                            CD.spec.ingress:
                                            <br/>
                                            ingress:
                                            <br/>
                                            - domain: apps.{CLUSTER_NAME_2}.qe.devcluster.openshift.com
                                            <br/>
                                            httpErrorCodePages:
                                            <br/>
                                            name: custom-error-pages-test
                                            <br/>
                                            name: default
                                        </p>
                                    </html>
                                </item>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            Cluster provision completes and reaches "Provisioned" status, but may be in "WaitingForClusterOperators" state initially.
                                        </p>
                                    </html>
                                </item>
                            </values>
                        </testStep>
                        
                        <!-- Step: Verify custom httpErrorCodePages in SyncSet -->
                        <testStep>
                            <values>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            Verify that the httpErrorCodePages.name field in the SyncSet is custom-error-pages-test.
                                        </p>
                                    </html>
                                </item>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            SyncSet is created with httpErrorCodePages.name field set to "custom-error-pages-test".
                                        </p>
                                    </html>
                                </item>
                            </values>
                        </testStep>
                        
                        <!-- Step: Check IngressController with custom value -->
                        <testStep>
                            <values>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            Log in to the spoke cluster and check the IngressController configuration.
                                        </p>
                                    </html>
                                </item>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            IngressController in spoke cluster has httpErrorCodePages.name field set to "custom-error-pages-test".
                                        </p>
                                    </html>
                                </item>
                            </values>
                        </testStep>
                        
                        <!-- Step 2: Create and apply SelectorSyncSet -->
                        <testStep>
                            <values>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            2. Create and apply a SelectorSyncSet configuration file.
                                            <br/>
                                            <br/>
                                            % cat SelectorSyncSet-2040.yaml
                                            <br/>
                                            apiVersion: hive.openshift.io/v1
                                            <br/>
                                            kind: SelectorSyncSet
                                            <br/>
                                            metadata:
                                            <br/>
                                            name: httperror-configmaps
                                            <br/>
                                            spec:
                                            <br/>
                                            clusterDeploymentSelector:
                                            <br/>
                                            matchLabels:
                                            <br/>
                                            httperror: enabled
                                            <br/>
                                            resourceApplyMode: Sync
                                            <br/>
                                            resources:
                                            <br/>
                                            - apiVersion: v1
                                            <br/>
                                            kind: ConfigMap
                                            <br/>
                                            metadata:
                                            <br/>
                                            name: custom-error-pages-test
                                            <br/>
                                            namespace: openshift-config
                                            <br/>
                                            data:
                                            <br/>
                                            404.html: |
                                            <br/>
                                            &lt;html&gt;&lt;body&gt;&lt;h1&gt;My Custom 404 Page&lt;/h1&gt;&lt;/body&gt;&lt;/html&gt;
                                            <br/>
                                            503.html: |
                                            <br/>
                                            &lt;html&gt;&lt;body&gt;&lt;h1&gt;My Custom 503 Page&lt;/h1&gt;&lt;/body&gt;&lt;/html&gt;
                                            <br/>
                                            <br/>
                                            % oc apply -f SelectorSyncSet-2040.yaml
                                        </p>
                                    </html>
                                </item>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            SelectorSyncSet is successfully applied and ConfigMap "custom-error-pages-test" is created in the openshift-config namespace with 2 data entries.
                                        </p>
                                    </html>
                                </item>
                            </values>
                        </testStep>
                        
                        <!-- Step 3: Wait for cluster to reach Running state -->
                        <testStep>
                            <values>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            3. Wait for the ConfigMap to take effect and for the cluster to reach the Running state.
                                        </p>
                                    </html>
                                </item>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            Cluster reaches "Running" power state indicating all components are operational.
                                        </p>
                                    </html>
                                </item>
                            </values>
                        </testStep>
                        
                        <!-- Step 4: Check Cluster Operators are Ready -->
                        <testStep>
                            <values>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            4. Log in to the spoke cluster and check that all Cluster Operators are Ready.
                                        </p>
                                    </html>
                                </item>
                                <item>
                                    <html>
                                        <p xmlns="http://www.w3.org/1999/xhtml">
                                            All Cluster Operators are in "Available=True" state with "Progressing=False" and "Degraded=False", indicating the cluster is fully operational.
                                        </p>
                                    </html>
                                </item>
                            </values>
                        </testStep>
                    </steps>
                </testSteps>
            </field>
        </customFields>
    </workItem>
</workItems>
